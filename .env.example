# ============================================
# unerr Web Landing - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ============================================
# Supabase (PostgreSQL)
# ============================================
# Direct PostgreSQL connection string (for Prisma)
# Get from: https://supabase.com/dashboard/project/_/settings/database
# This landing site uses the "landing" schema to avoid conflicts
# with the main app sharing the same Supabase database.
SUPABASE_DB_URL=postgresql://postgres.yourproject:password@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# ============================================
# Better Auth
# ============================================
# Secret key (REQUIRED - minimum 32 characters)
# Generate: openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-key-minimum-32-characters-long-change-this

# Base URL for this landing site
# Development: http://localhost:3000
# Production: https://unerr-web.fly.dev
BETTER_AUTH_URL=http://localhost:3000

# ============================================
# Google OAuth (Optional)
# ============================================
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# PostHog Analytics (Optional)
# ============================================
# Get from: https://us.posthog.com/settings/project
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# Public
# ============================================
# This landing site's public URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# The main unerr app server URL (for "Get Started" links)
NEXT_PUBLIC_UNERR_APP_SERVER=http://localhost:3001
